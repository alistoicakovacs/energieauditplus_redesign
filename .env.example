# EnergieAudit Plus — environment variables
#
# The contact-form backend (server/contact.js + server/mailer.js, exposed via
# api/contact.js) reads these on the SERVER ONLY. They are NEVER imported into
# client code and must never appear in dist/. Copy this file to `.env` and fill
# in real values for production. For LOCAL dev you can leave them all unset:
# without RESEND_API_KEY the mailer logs the composed email instead of sending,
# so the whole flow is testable with zero credentials and zero external calls.

# --- Contact form: transactional mail (Resend) ---
# Server-only API key. UNSET in dev ⇒ emails are logged, not sent.
RESEND_API_KEY=

# Where notification emails are delivered (the EA+ inbox).
# TODO (client, plan §12.3): confirm the real recipient mailbox.
CONTACT_TO=team@ea-plus.de

# Verified Resend sender (must be on a domain verified in Resend).
# TODO (client): set up + verify the sending domain.
CONTACT_FROM=EnergieAudit Plus <noreply@ea-plus.de>

# Comma-separated extra origins allowed to POST the form (same-origin check,
# plan §8.1). The production site origin and localhost dev origins are allowed
# by default; add others here if needed.
# ALLOWED_ORIGINS=https://ea-plus.de,https://www.ea-plus.de

# Number of TRUSTED reverse proxies between the public internet and this
# process — used to pick the real client IP for rate-limiting from
# X-Forwarded-For (see server/requestUtils.js clientIp). MUST match the
# deployment topology:
#   0 = direct connection, no proxy (X-Forwarded-For is NOT trusted; the local
#       dev harness defaults to 0)
#   1 = exactly one trusted proxy in front (typical single edge/CDN, e.g.
#       Vercel — which also sets the non-forgeable x-vercel-forwarded-for that
#       is preferred automatically). This is the code default.
#   N = N trusted proxies; the client IP is taken N entries from the RIGHT of
#       the XFF chain so client-forged left-side entries can't evade the cap.
# Setting this too LOW trusts a forgeable entry; too HIGH reads a proxy address.
# TRUSTED_PROXY_HOPS=1

# Canonical site origin (used for the same-origin allow-list on the server and
# for absolute URLs in <Seo>/JSON-LD on the client via VITE_SITE_URL).
# SITE_URL=https://ea-plus.de
# VITE_SITE_URL=https://ea-plus.de

# --- Local dev harness (server/dev-server.mjs) ---
# Port the harness listens on; vite.config.js proxies /api/contact here.
# CONTACT_DEV_PORT=8787
